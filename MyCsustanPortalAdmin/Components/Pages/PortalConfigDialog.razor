@inject IDbContextFactory<MyCsustanContext> DbFactory
@inject DialogService DialogService

<RadzenTemplateForm Data="@_model" TItem="PortalConfig" Submit="OnSubmit">
    <RadzenFieldset Text="Portal Config">
        <RadzenStack Gap="1rem">
            <RadzenFormField Text="PeopleSoft CS Base URL" AllowFloatingLabel="false">
                <RadzenDropDown Data="_baseUrls" TextProperty="BaseUrlName" ValueProperty="BaseUrlId" @bind-Value="_model.PeopleSoftCsBaseUrlId" Style="width: 100%" />
            </RadzenFormField>
            <RadzenFormField Text="PeopleSoft HR Base URL" AllowFloatingLabel="false">
                <RadzenDropDown Data="_baseUrls" TextProperty="BaseUrlName" ValueProperty="BaseUrlId" @bind-Value="_model.PeopleSoftHrBaseUrlId" Style="width: 100%" />
            </RadzenFormField>
            <RadzenFormField Text="CashNet Base URL" AllowFloatingLabel="false">
                <RadzenDropDown Data="_baseUrls" TextProperty="BaseUrlName" ValueProperty="BaseUrlId" @bind-Value="_model.CashetBaseUrlId" Style="width: 100%" />
            </RadzenFormField>
            <RadzenFormField Text="Campus Website Base URL" AllowFloatingLabel="false">
                <RadzenDropDown Data="_baseUrls" TextProperty="BaseUrlName" ValueProperty="BaseUrlId" @bind-Value="_model.CampusWebsiteBaseUrlId" Style="width: 100%" />
            </RadzenFormField>
            <RadzenFormField Text="Draw Base URL" AllowFloatingLabel="false">
                <RadzenDropDown Data="_baseUrls" TextProperty="BaseUrlName" ValueProperty="BaseUrlId" @bind-Value="_model.DrawBaseUrlId" Style="width: 100%" AllowClear="true" />
            </RadzenFormField>
            <RadzenFormField Text="Covid Screening Link Group" AllowFloatingLabel="false">
                <RadzenDropDown Data="_linkGroups" TextProperty="PortalLinkGroupName" ValueProperty="PortalLinkGroupId" @bind-Value="_model.CovidScreeningPortalLinkGroupId" Style="width: 100%" AllowClear="true" />
            </RadzenFormField>
            <RadzenFormField Text="Masked Emplid" AllowFloatingLabel="false">
                <RadzenTextBox @bind-Value="_model.MaskedEmplid" Name="MaskedEmplid" Style="width: 100%" />
            </RadzenFormField>
            <RadzenFormField Text="Masked SSN" AllowFloatingLabel="false">
                <RadzenTextBox @bind-Value="_model.MaskedSsn" Name="MaskedSsn" Style="width: 100%" />
            </RadzenFormField>
        </RadzenStack>
    </RadzenFieldset>

    <RadzenStack Orientation="Orientation.Horizontal" JustifyContent="JustifyContent.SpaceBetween" class="rz-mt-3">
        <RadzenButton Text="Delete" ButtonStyle="ButtonStyle.Danger" Click="OnDelete" Visible="@(_model.PortalConfigId != 0)" />
        <RadzenStack Orientation="Orientation.Horizontal" Gap="0.5rem">
            <RadzenButton Text="Save" ButtonStyle="ButtonStyle.Primary" Type="ButtonType.Submit" />
            <RadzenButton Text="Cancel" ButtonStyle="ButtonStyle.Light" Click="() => DialogService.Close(false)" />
        </RadzenStack>
    </RadzenStack>
</RadzenTemplateForm>

@code {
    [Parameter] public int? PortalConfigId { get; set; }

    private PortalConfig _model = new();
    private List<BaseUrl> _baseUrls = new();
    private List<PortalLinkGroup> _linkGroups = new();

    protected override async Task OnInitializedAsync()
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        _baseUrls = await db.BaseUrls.AsNoTracking().OrderBy(b => b.BaseUrlName).ToListAsync();
        _linkGroups = await db.PortalLinkGroups.AsNoTracking().OrderBy(g => g.PortalLinkGroupName).ToListAsync();

        if (PortalConfigId is null)
        {
            return;
        }

        var entity = await db.PortalConfigs.FindAsync(PortalConfigId.Value);
        if (entity is not null)
        {
            _model = entity;
        }
    }

    private async Task OnSubmit(PortalConfig model)
    {
        await using var db = await DbFactory.CreateDbContextAsync();

        if (model.PortalConfigId == 0)
        {
            db.PortalConfigs.Add(model);
        }
        else
        {
            db.PortalConfigs.Update(model);
        }

        await db.SaveChangesAsync();
        DialogService.Close(true);
    }

    private async Task OnDelete()
    {
        var confirm = await DialogService.Confirm("Delete this portal config?", "Confirm Delete");
        if (confirm != true)
        {
            return;
        }

        await using var db = await DbFactory.CreateDbContextAsync();
        var entity = await db.PortalConfigs.FindAsync(_model.PortalConfigId);
        if (entity is not null)
        {
            db.PortalConfigs.Remove(entity);
            await db.SaveChangesAsync();
        }

        DialogService.Close(true);
    }
}
