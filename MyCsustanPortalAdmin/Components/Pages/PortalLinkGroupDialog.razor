@inject IDbContextFactory<MyCsustanContext> DbFactory
@inject DialogService DialogService

<RadzenTemplateForm Data="@_model" TItem="PortalLinkGroup" Submit="OnSubmit">
    <RadzenFieldset Text="Portal Link Group">
        <RadzenStack Gap="1rem">
            <RadzenFormField Text="Group Name" AllowFloatingLabel="false">
                <RadzenTextBox @bind-Value="_model.PortalLinkGroupName" Name="PortalLinkGroupName" Style="width: 100%" />
            </RadzenFormField>
            <RadzenFormField Text="Sort Order" AllowFloatingLabel="false">
                <RadzenNumeric TValue="int?" @bind-Value="_model.SortOrder" Name="SortOrder" Style="width: 100%" />
            </RadzenFormField>
            <RadzenFormField Text="All Users" AllowFloatingLabel="false">
                <RadzenCheckBox @bind-Value="_model.AllUsers" Name="AllUsers" />
            </RadzenFormField>
            <RadzenFormField Text="Inactive" AllowFloatingLabel="false">
                <RadzenCheckBox @bind-Value="_model.IsInactive" Name="IsInactive" />
            </RadzenFormField>

            <RadzenFieldset Text="Roles">
                <RadzenFormField Text="Role Assignments" AllowFloatingLabel="false">
                    <RadzenListBox Data="_roles"
                                   TextProperty="RoleName"
                                   ValueProperty="PortalRoleId"
                                   Multiple="true"
                                   @bind-Value="_selectedRoleIds"
                                   Style="width: 100%; max-height: 240px" />
                </RadzenFormField>
            </RadzenFieldset>
        </RadzenStack>
    </RadzenFieldset>

    <RadzenStack Orientation="Orientation.Horizontal" JustifyContent="JustifyContent.SpaceBetween" class="rz-mt-3">
        <RadzenButton Text="Delete" ButtonStyle="ButtonStyle.Danger" Click="OnDelete" Disabled="@(_model.PortalLinkGroupId == 0)" />
        <RadzenStack Orientation="Orientation.Horizontal" Gap="0.5rem">
            <RadzenButton Text="Save" ButtonStyle="ButtonStyle.Primary" Type="ButtonType.Submit" />
            <RadzenButton Text="Cancel" ButtonStyle="ButtonStyle.Light" Click="() => DialogService.Close(false)" />
        </RadzenStack>
    </RadzenStack>
</RadzenTemplateForm>

@code {
    [Parameter] public int? PortalLinkGroupId { get; set; }

    private PortalLinkGroup _model = new();
    private List<PortalRole> _roles = new();
    private IList<int> _selectedRoleIds = new List<int>();

    protected override async Task OnInitializedAsync()
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        _roles = await db.PortalRoles.AsNoTracking().OrderBy(r => r.RoleName).ToListAsync();

        if (PortalLinkGroupId is null)
        {
            return;
        }

        var entity = await db.PortalLinkGroups
            .Include(g => g.PortalRoles)
            .FirstOrDefaultAsync(g => g.PortalLinkGroupId == PortalLinkGroupId.Value);

        if (entity is not null)
        {
            _model = entity;
            _selectedRoleIds = entity.PortalRoles.Select(r => r.PortalRoleId).ToList();
        }
    }

    private async Task OnSubmit(PortalLinkGroup model)
    {
        await using var db = await DbFactory.CreateDbContextAsync();

        PortalLinkGroup entity;
        if (model.PortalLinkGroupId == 0)
        {
            entity = new PortalLinkGroup();
            db.PortalLinkGroups.Add(entity);
        }
        else
        {
            entity = await db.PortalLinkGroups
                .Include(g => g.PortalRoles)
                .FirstAsync(g => g.PortalLinkGroupId == model.PortalLinkGroupId);
        }

        entity.PortalLinkGroupName = model.PortalLinkGroupName;
        entity.AllUsers = model.AllUsers;
        entity.IsInactive = model.IsInactive;
        entity.SortOrder = model.SortOrder;

        entity.PortalRoles.Clear();
        var selectedRoles = await db.PortalRoles
            .Where(r => _selectedRoleIds.Contains(r.PortalRoleId))
            .ToListAsync();
        foreach (var role in selectedRoles)
        {
            entity.PortalRoles.Add(role);
        }

        await db.SaveChangesAsync();
        DialogService.Close(true);
    }

    private async Task OnDelete()
    {
        var confirm = await DialogService.Confirm("Delete this link group?", "Confirm Delete");
        if (confirm != true)
        {
            return;
        }

        await using var db = await DbFactory.CreateDbContextAsync();
        var entity = await db.PortalLinkGroups.FindAsync(_model.PortalLinkGroupId);
        if (entity is not null)
        {
            db.PortalLinkGroups.Remove(entity);
            await db.SaveChangesAsync();
        }

        DialogService.Close(true);
    }
}
