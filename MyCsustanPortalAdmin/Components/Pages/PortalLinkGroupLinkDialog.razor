@inject IDbContextFactory<MyCsustanContext> DbFactory
@inject DialogService DialogService

<RadzenTemplateForm Data="@_model" TItem="PortalLinkGroupLink" Submit="OnSubmit">
    <RadzenFieldset Text="Group Link">
        <RadzenStack Gap="1rem">
            <RadzenFormField Text="Portal Link" AllowFloatingLabel="false">
                <RadzenDropDown Data="_links"
                                TextProperty="Title"
                                ValueProperty="PortalLinkId"
                                @bind-Value="_model.PortalLinkId"
                                Disabled="@(_isExisting)"
                                Style="width: 100%" />
            </RadzenFormField>
            <RadzenFormField Text="Sort Order" AllowFloatingLabel="false">
                <RadzenNumeric TValue="int?" @bind-Value="_model.SortOrder" Name="SortOrder" Style="width: 100%" />
            </RadzenFormField>
        </RadzenStack>
    </RadzenFieldset>

    <RadzenStack Orientation="Orientation.Horizontal" JustifyContent="JustifyContent.SpaceBetween" class="rz-mt-3">
        <RadzenButton Text="Delete" ButtonStyle="ButtonStyle.Danger" Click="OnDelete" Disabled="@(!_isExisting)" />
        <RadzenStack Orientation="Orientation.Horizontal" Gap="0.5rem">
            <RadzenButton Text="Save" ButtonStyle="ButtonStyle.Primary" Type="ButtonType.Submit" />
            <RadzenButton Text="Cancel" ButtonStyle="ButtonStyle.Light" Click="() => DialogService.Close(false)" />
        </RadzenStack>
    </RadzenStack>
</RadzenTemplateForm>

@code {
    [Parameter] public int PortalLinkGroupId { get; set; }
    [Parameter] public int? PortalLinkId { get; set; }

    private PortalLinkGroupLink _model = new();
    private List<PortalLink> _links = new();
    private bool _isExisting;

    protected override async Task OnInitializedAsync()
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        _links = await db.PortalLinks.AsNoTracking().OrderBy(l => l.Title).ToListAsync();

        if (PortalLinkId is null)
        {
            _model.PortalLinkGroupId = PortalLinkGroupId;
            return;
        }

        var entity = await db.PortalLinkGroupLinks.FindAsync(PortalLinkGroupId, PortalLinkId.Value);
        if (entity is not null)
        {
            _model = entity;
            _isExisting = true;
        }
    }

    private async Task OnSubmit(PortalLinkGroupLink model)
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        model.PortalLinkGroupId = PortalLinkGroupId;

        if (_isExisting)
        {
            db.PortalLinkGroupLinks.Update(model);
        }
        else
        {
            db.PortalLinkGroupLinks.Add(model);
        }

        await db.SaveChangesAsync();
        DialogService.Close(true);
    }

    private async Task OnDelete()
    {
        var confirm = await DialogService.Confirm("Delete this link?", "Confirm Delete");
        if (confirm != true)
        {
            return;
        }

        await using var db = await DbFactory.CreateDbContextAsync();
        var entity = await db.PortalLinkGroupLinks.FindAsync(PortalLinkGroupId, PortalLinkId!.Value);
        if (entity is not null)
        {
            db.PortalLinkGroupLinks.Remove(entity);
            await db.SaveChangesAsync();
        }

        DialogService.Close(true);
    }
}
