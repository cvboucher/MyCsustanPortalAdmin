@inject IDbContextFactory<MyCsustanContext> DbFactory
@inject DialogService DialogService

<RadzenTemplateForm Data="@_model" TItem="ComputerLab" Submit="OnSubmit">
    <RadzenFieldset Text="Computer Lab">
        <RadzenFormField Text="Lab Name" AllowFloatingLabel="false">
            <RadzenTextBox @bind-Value="_model.ComputerLabName" Name="ComputerLabName" Style="width: 100%" />
        </RadzenFormField>
    </RadzenFieldset>

    <RadzenStack Orientation="Orientation.Horizontal" JustifyContent="JustifyContent.SpaceBetween" class="mt-3">
        <RadzenButton Text="Delete" ButtonStyle="ButtonStyle.Danger" Click="OnDelete" Disabled="@(_model.ComputerLabId == 0)" />
        <RadzenStack Orientation="Orientation.Horizontal" Gap="0.5rem">
            <RadzenButton Text="Save" ButtonStyle="ButtonStyle.Primary" Type="ButtonType.Submit" />
            <RadzenButton Text="Cancel" ButtonStyle="ButtonStyle.Light" Click="() => DialogService.Close(false)" />
        </RadzenStack>
    </RadzenStack>
</RadzenTemplateForm>

@code {
    [Parameter] public int? ComputerLabId { get; set; }

    private ComputerLab _model = new();

    protected override async Task OnInitializedAsync()
    {
        if (ComputerLabId is null)
        {
            return;
        }

        await using var db = await DbFactory.CreateDbContextAsync();
        var entity = await db.ComputerLabs.FindAsync(ComputerLabId.Value);
        if (entity is not null)
        {
            _model = entity;
        }
    }

    private async Task OnSubmit(ComputerLab model)
    {
        await using var db = await DbFactory.CreateDbContextAsync();

        if (model.ComputerLabId == 0)
        {
            db.ComputerLabs.Add(model);
        }
        else
        {
            db.ComputerLabs.Update(model);
        }

        await db.SaveChangesAsync();
        DialogService.Close(true);
    }

    private async Task OnDelete()
    {
        var confirm = await DialogService.Confirm("Delete this computer lab?", "Confirm Delete");
        if (confirm != true)
        {
            return;
        }

        await using var db = await DbFactory.CreateDbContextAsync();
        var entity = await db.ComputerLabs.FindAsync(_model.ComputerLabId);
        if (entity is not null)
        {
            db.ComputerLabs.Remove(entity);
            await db.SaveChangesAsync();
        }

        DialogService.Close(true);
    }
}
