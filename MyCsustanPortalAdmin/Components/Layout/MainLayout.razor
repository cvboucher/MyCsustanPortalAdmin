@inherits LayoutComponentBase

<RadzenLayout>
    <RadzenHeader>
        <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" JustifyContent="JustifyContent.SpaceBetween" Style="width: 100%">
            <RadzenText Text="MyCsustan Portal Admin" Style="font-size: 1.1rem; font-weight: 600;" />
        </RadzenStack>
    </RadzenHeader>

    <RadzenSidebar @bind-Expanded="_sidebarExpanded" Style="width: 260px">
        <RadzenPanelMenu>
            <RadzenPanelMenuItem Text="Home" Icon="home" Path="/" />
            <RadzenPanelMenuItem Text="Admin Users" Icon="group" Path="/admin-users" />
            <RadzenPanelMenuItem Text="Portal Links" Icon="link" Path="/portal-links" />
            <RadzenPanelMenuItem Text="Portal Link Groups" Icon="folder" Path="/portal-link-groups" />
            <RadzenPanelMenuItem Text="Portal Roles" Icon="security" Path="/portal-roles" />
            <RadzenPanelMenuItem Text="Portal Config" Icon="settings" Path="/portal-config" />
            <RadzenPanelMenuItem Text="Base URLs" Icon="link" Path="/base-urls" />
            <RadzenPanelMenuItem Text="PeopleSoft Instances" Icon="dns" Path="/peoplesoft-instances" />
            <RadzenPanelMenuItem Text="Dates & Deadlines" Icon="event" Path="/dates-deadlines" />
            <RadzenPanelMenuItem Text="Default Dashboard Pages" Icon="dashboard" Path="/default-dashboard-pages" />
            <RadzenPanelMenuItem Text="User Profiles" Icon="person" Path="/user-profiles" />
            <RadzenPanelMenuItem Text="Stan Communications" Icon="campaign" Path="/stan-communications" />
            <RadzenPanelMenuItem Text="RSS Feeds" Icon="rss_feed" Path="/rss-feeds" />
            <RadzenPanelMenuItem Text="NSSE Survey Files" Icon="description" Path="/nsse-survey-files" />
            <RadzenPanelMenuItem Text="NSSE Survey Links" Icon="link" Path="/nsse-survey-links" />
            <RadzenPanelMenuItem Text="PurpleAir Sensors" Icon="air" Path="/purple-air-sensors" />
            <RadzenPanelMenuItem Text="ADF Widgets" Icon="widgets" Path="/adf-widgets" />
            <RadzenPanelMenuItem Text="Computer Labs" Icon="dns" Path="/computer-labs" />
            <RadzenPanelMenuItem Text="Lab Hours" Icon="schedule" Path="/computer-lab-hours" />
        </RadzenPanelMenu>
    </RadzenSidebar>

    <RadzenBody>
        <div class="main-body">
            @Body
        </div>
        <RadzenDialog />
    </RadzenBody>
</RadzenLayout>

@code {
    private bool _sidebarExpanded = true;
}
